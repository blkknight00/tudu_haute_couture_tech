# TuDu API - Apache Configuration
# Pass the Authorization header through to PHP
# (Apache strips it by default when PHP runs as CGI/FastCGI)

Options -Indexes

# CRITICAL: Pass Authorization header to PHP
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
RewriteEngine On
RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

